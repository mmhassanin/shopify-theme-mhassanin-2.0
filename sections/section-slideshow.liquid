{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_id = '#section-' | append: section.id
  assign slider_id = '#slider-' | append: section.id
  assign slider_id_2 = '#slider-2-' | append: section.id
  assign controls_id = '#controls-' | append: section.id
  assign slideshow_height = section.settings.slideshow_height
  assign disable_lazyload = section.settings.disable_lazyload
  assign right_sidebar = section.settings.right_sidebar
  assign items_resp = '1'
  assign gallery_blocks = section.blocks | where: 'type', 'block-item'
  assign limit = gallery_blocks.size
-%}

<div
  class="section-slideshow{% if right_sidebar != 'none' %} sidebar-{{ right_sidebar }}{% endif %} {{ section.settings.section_visibility }}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="featured-blog"
>
  <div
    class="
      {{ section.settings.section_layout }}
      {{ slideshow_height }}
    "
  >
    <div class="section-wrapper push-layout-{{ section.settings.push_layout_right }}">
      <div class="section-body{% if right_sidebar == 'banner' %} style-{{ section.settings.three_banner_style }}{% endif %}">
        <div class="bc-slideshow-wrapper">
          <div class="bc-slideshow">
            <slider-component id="slideshow-media-main">
              <div class="slider-container js-slider-container">
                <div class="slider-wrapper">
                  <div class="slider-list" id="slider-{{ section.id }}">
                    {%- for block in section.blocks -%}
                      {%- case block.type -%}
                        {%- when 'block-item' -%}
                          {%- liquid
                            assign image = block.settings.image
                            if block.settings.image_mobile == blank
                              assign image_mobile = block.settings.image
                            else
                              assign image_mobile = block.settings.image_mobile
                            endif
                          -%}

                          {%- capture block_id -%}.slide-{{ block.id }}{%- endcapture -%}

                          <div class="slider-item slide-{{ block.id }} position-{{ block.settings.text_position }} mobile-position-{{ block.settings.text_position_mobile }}">
                            <a
                              href="{{ block.settings.link | default: 'javascript:void(0)' }}"
                              class="slide-bg"
                              aria-label="Slideshow image"
                            >
                              {%- if forloop.first -%}
                                {%- if image == blank and image_mobile == blank -%}
                                  {%- render 'image-style',
                                    image: image,
                                    class: 'image-desktop',
                                    placeholder_type: 'hero'
                                  -%}
                                {%- else -%}
                                  {%- render 'image-style',
                                    image: image,
                                    class: 'image-desktop',
                                    preload: true,
                                    preloadType: 'desktop',
                                    dislazy: disable_lazyload
                                  -%}
                                  {%- render 'image-style',
                                    image: image_mobile,
                                    class: 'image-mobile',
                                    preload: true,
                                    preloadType: 'mobile',
                                    dislazy: disable_lazyload
                                  -%}
                                {%- endif -%}
                              {%- else -%}
                                {%- if image == blank and image_mobile == blank -%}
                                  {%- render 'image-style',
                                    image: image,
                                    class: 'image-desktop',
                                    placeholder_type: 'hero'
                                  -%}
                                {%- else -%}
                                  {%- render 'image-style', image: image, class: 'image-desktop' -%}
                                  {%- render 'image-style', image: image_mobile, class: 'image-mobile' -%}
                                {%- endif -%}
                              {%- endif -%}
                            </a>

                            <div class="slide-content text-{{ block.settings.text_alignment }}{% if block.settings.hide_content_mobile %} hide-mobile{% endif %}">
                              <div class="slide-content-wrapper">
                                <div
                                  class="slide-content-inner"
                                  style="--pos-x-desk: {{ block.settings.caption_x_desktop }}%; --pos-y-desk: {{ block.settings.caption_y_desktop }}%; --pos-x-mob: {{ block.settings.caption_x_mobile }}%; --pos-y-mob: {{ block.settings.caption_y_mobile }}%;"
                                >
                                  <div
                                    class="slide-caption-animation-container{% if block.settings.enable_caption_animation %} animate-{{ block.settings.caption_animation_type }}{% endif %}"
                                    style="--anim-duration: {{ block.settings.animation_duration }}s;"
                                  >
                                    {%- if block.settings.heading != blank -%}
                                      <span class="image-gallery_title content-text-1">
                                        {{- block.settings.heading -}}
                                      </span>
                                    {%- endif -%}
                                    {%- if block.settings.subtext != blank -%}
                                      <span class="image-gallery_subtext content-text-2">
                                        {{- block.settings.subtext -}}
                                      </span>
                                    {%- endif -%}
                                    {%- if block.settings.subtext_2 != blank -%}
                                      <span class="image-gallery_subtext_2 content-text-3">
                                        {{- block.settings.subtext_2 -}}
                                      </span>
                                    {%- endif -%}
                                    {%- if block.settings.button_label != blank -%}
                                      <a
                                        href="{{ block.settings.link | default: 'javascript:void(0)' }}"
                                        class="btn btn-1 btn-slideshow btn-slide content-button"
                                      >
                                        {{ block.settings.button_label }}
                                      </a>
                                    {%- endif -%}
                                  </div>
                                </div>

                                {%- unless block.settings.text_bg_color == blank
                                  or block.settings.text_bg_color == 'rgba(0,0,0,0)'
                                -%}
                                  {%- style -%}
                                    .slide-{{ block.id }} .slide-content-inner{
                                      width: 540px;
                                      padding: 19px 45px 24px 45px;
                                      background: {{ block.settings.text_bg_color }};
                                      border-radius: 19px;
                                    }
                                    @media (max-width: 767px) {
                                      .slide-{{ block.id }} .slide-content-inner{
                                        max-width: 80%;
                                        padding: 20px;
                                      }
                                    }
                                  {%- endstyle -%}
                                {%- endunless -%}
                              </div>

                              {%- if block.settings.image_layout != blank -%}
                                <div class="image-layer-box">
                                  <div class="image-layer-slide">
                                    <a
                                      href="{{ block.settings.link | default: 'javascript:void(0)' }}"
                                      aria-label="Image layout"
                                    >
                                      {%- if forloop.first -%}
                                        {%- render 'image-style',
                                          image: block.settings.image_layout,
                                          limit: 768,
                                          preload: true,
                                          dislazy: disable_lazyload
                                        -%}
                                      {%- else -%}
                                        {%- render 'image-style', image: block.settings.image_layout, limit: 768 -%}
                                      {%- endif -%}
                                    </a>
                                  </div>
                                </div>
                              {%- endif -%}
                            </div>

                            {%- for block in section.blocks offset: forloop.index -%}
                              {%- if block.type == 'block-item' -%}{%- break -%}{%- endif -%}
                              {%- assign block_type = block.type | remove: 'style_' -%}
                              {%- capture block_css -%}
                                  {%- render 'snippet-slideshow-style', type: block_type, sectionID: section_id, block: block, blockID: block_id -%}
                                {%- endcapture -%}
                              {%- unless block_css == blank -%}
                                <style {{ block.shopify_attributes }}>
                                  {{ block_css }}
                                </style>
                              {%- endunless -%}
                            {%- endfor -%}
                          </div>

                        {%- else -%}
                      {%- endcase -%}
                    {%- endfor -%}
                  </div>

                  {%- render 'set-tns-config',
                    slider_id: slider_id,
                    classID: section_id,
                    loop: section.settings.loop,
                    dots: section.settings.dots,
                    controls: section.settings.controls,
                    controls_id: controls_id,
                    customControls: true,
                    autoplay: section.settings.autoplay,
                    autoplay_timeout: section.settings.autoplay_timeout,
                    items_resp: items_resp,
                    total_item: limit
                  -%}
                </div>
              </div>
            </slider-component>
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'category' -%}
              <div class="block-categories">
                {%- for i in (1..5) -%}
                  {%- assign heading_ind = 'heading_' | append: i -%}
                  {%- assign collection_ind = 'collection_' | append: i -%}
                  {%- assign collection = collections[block.settings[collection_ind]] -%}

                  {% unless block.settings[collection_ind] == blank %}
                    <div class="collection-card">
                      <div class="collection-card_image">
                        <a href="{{ collection.url }}">
                          {%- render 'image-style', image: collection.image -%}
                        </a>
                      </div>
                      <div class="collection-card_title text-center">
                        <a href="{{ collection.url }}">
                          {%- if block.settings[heading_ind] == 'blank' -%}
                            {{ collection.title }}
                          {%- else -%}
                            {{ block.settings[heading_ind] }}
                          {%- endif -%}
                        </a>
                      </div>
                    </div>
                  {% endunless %}
                {%- endfor -%}
              </div>
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if right_sidebar != 'none' -%}
          {%- if right_sidebar == 'product' -%}
            <div class="bc-three-products">
              <slider-component id="slideshow-three-products">
                <div class="slider-container js-slider-container">
                  <div class="slider-wrapper">
                    <div class="slider-list" id="slider-2-{{ section.id }}">
                      {%- assign number = 0 -%}
                      {%- for i in (1..3) -%}
                        {%- assign product_ind = 'product_' | append: i -%}
                        {%- assign product_index = section.settings[product_ind] -%}

                        {%- unless product_index == blank -%}
                          {%- assign number = number | plus: 1 -%}
                          {%- assign product = all_products[product_index] -%}
                          <div class="slider-item">
                            {%- render 'product-item', product: product -%}
                          </div>
                        {%- endunless -%}
                      {%- endfor -%}
                    </div>

                    {%- capture controls_id -%}#controls-three-products{%- endcapture -%}

                    {%- render 'set-tns-config',
                      slider_id: slider_id_2,
                      loop: true,
                      dots: false,
                      controls: true,
                      controls_id: controls_id,
                      autoplay: false,
                      items_resp: 1,
                      total_item: number
                    -%}
                  </div>
                </div>
              </slider-component>
            </div>

          {%- else -%}
            {%- if right_sidebar == 'banner' -%}
              {%- assign number_i = 3 -%}
            {%- else -%}
              {%- assign number_i = 2 -%}
            {%- endif -%}

            <div class="bc-three-banner style-{{ section.settings.three_banner_style }}">
              {%- for i in (1..number_i) -%}
                {%- assign three_image = 'three_image_' | append: i -%}

                {% unless section.settings[three_image] == blank %}
                  {%- assign three_text = 'three_text_' | append: i -%}
                  {%- assign three_button = 'three_button_' | append: i -%}
                  {%- assign three_link = 'three_link_' | append: i -%}

                  <div class="bc-item">
                    <div class="bc-item-inner" style="background: {{ section.settings.three_image_bg_color }};">
                      <div class="bc-item-left">
                        <a href="{{ section.settings[three_link] }}">
                          {%- render 'image-style', image: section.settings[three_image], limit: 150 -%}
                        </a>
                      </div>

                      <div class="bc-item-body">
                        {% unless section.settings[three_text] == blank %}
                          <div class="bc-item-text">
                            <a href="{{ section.settings[three_link] }}">{{ section.settings[three_text] }}</a>
                          </div>
                        {% endunless %}
                        {% unless section.settings[three_button] == blank %}
                          <a class="bc-item-btn" href="{{ section.settings[three_link] }}">
                            <span>{{ section.settings[three_button] }}</span>
                            <span class="btn-icon">{%- render 'svg', type: 'angle-right' -%}</span>
                          </a>
                        {% endunless %}
                      </div>
                    </div>
                  </div>
                {% endunless %}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  window.theme = window.theme || {};
  if (!!window.theme.sectionRegister) {
    !window.theme.sectionRegister.includes('featured-blog') &&
      (window.theme.sectionRegister = [...window.theme.sectionRegister, 'featured-blog']);
  } else {
    window.theme.sectionRegister = ['featured-blog'];
  }
</script>

<script>
  window.theme = window.theme || {};
  if (!!window.theme.customElementsList) {
    !window.theme.customElementsList.includes('slider-component') &&
      (window.theme.customElementsList = [...window.theme.customElementsList, 'slider-component']);
  } else {
    window.theme.customElementsList = ['slider-component'];
  }
</script>

{%- capture section_css -%}
  {%- render 'snippet-theme', type: 'section-style', preClassID: section_id, config: section.settings -%}
  {%- if slideshow_height == 'fix-height' -%}
    .section-slideshow#section-{{ section.id }} .bc-slideshow {
      height: {{ section.settings.manually_height | times: 0.65 | round }}px;
    }
    @media (min-width: 768px) {
      .section-slideshow#section-{{ section.id }} .bc-slideshow {
        height: {{ section.settings.manually_height }}px;
      }
    }
  {%- elsif slideshow_height == 'auto-height' -%}
    {%- assign first_slide = section.blocks | where: 'type', 'block-item' | first -%}
    {%- assign ar_desk = first_slide.settings.image.aspect_ratio | default: 2.333 -%}
    {%- assign img_mob = first_slide.settings.image_mobile | default: first_slide.settings.image -%}
    {%- assign ar_mob = img_mob.aspect_ratio | default: 1.0 -%}
    .section-slideshow#section-{{ section.id }} .bc-slideshow {
      height: auto;
      aspect-ratio: {{ ar_mob }};
    }
    @media (min-width: 768px) {
      .section-slideshow#section-{{ section.id }} .bc-slideshow {
        aspect-ratio: {{ ar_desk }};
      }
    }
  {%- elsif slideshow_height == 'full-height' -%}
    .section-slideshow#section-{{ section.id }} .bc-slideshow {
      height: 100vh;
      overflow: hidden;
    }
  {%- endif -%}

  /* Force inner elements to stretch correctly to the container's dictated height */
  .section-slideshow#section-{{ section.id }} .bc-slideshow .slider-item,
  .section-slideshow#section-{{ section.id }} .bc-slideshow .slide-bg,
  .section-slideshow#section-{{ section.id }} .bc-slideshow .image-desktop,
  .section-slideshow#section-{{ section.id }} .bc-slideshow .image-mobile {
    height: 100% !important;
  }
  .section-slideshow#section-{{ section.id }} .bc-slideshow .slide-bg img {
    height: 100% !important;
    width: 100% !important;
    object-fit: cover;
  }
  .section-slideshow#section-{{ section.id }} .bc-slideshow .slider-wrapper .tns-nav{
    bottom: {{ section.settings.dots_bottom_offset }}% !important;
  }
  @media (max-width: 767px) {
    .section-slideshow#section-{{ section.id }} .bc-slideshow .slider-wrapper .tns-nav{
      bottom: {{ section.settings.dots_bottom_offset_mobile }}% !important;
    }
  }

  /* Precision Positioning Overrides */
  .section-slideshow#section-{{ section.id }} .slide-content {
    max-width: none !important;
    padding: 0 !important;
  }
  .section-slideshow#section-{{ section.id }} .slide-content-inner {
    position: absolute !important;
    left: var(--pos-x-desk, 50%) !important;
    top: var(--pos-y-desk, 50%) !important;
    transform: translate(-50%, -50%) !important;
    margin: 0 !important;
    width: max-content !important;
    max-width: 90% !important;
    z-index: 10 !important;
  }
  @media (max-width: 767px) {
    .section-slideshow#section-{{ section.id }} .slide-content-inner {
      left: var(--pos-x-mob, 50%) !important;
      top: var(--pos-y-mob, 50%) !important;
    }
  }
{%- endcapture -%}

{%- style -%}{{ section_css | strip | strip_newlines | remove: '  ' }}{%- endstyle -%}

{%- schema -%}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_layout",
      "label": "t:settings_schema.global.settings.layout_mode.label",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "t:settings_schema.global.settings.layout_mode.options__1.label"
        },
        {
          "value": "layout-wide",
          "label": "t:settings_schema.global.settings.layout_mode.options__2.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "Section Visibility",
      "default": "always",
      "options": [
        { "value": "always", "label": "Both Desktop & Mobile" },
        { "value": "v-desktop-only", "label": "Desktop Only" },
        { "value": "v-mobile-only", "label": "Mobile Only" }
      ]
    },
    {
      "type": "select",
      "id": "right_sidebar",
      "label": "t:sections.common.right_sidebar",
      "default": "none",
      "options": [
        { "value": "banner", "label": "t:sections.common.image" },
        { "value": "overlay", "label": "t:sections.slideshow.settings.image_overlay_slideshow" },
        { "value": "product", "label": "t:sections.common.product" },
        { "value": "none", "label": "t:sections.common.none" }
      ]
    },
    {
      "type": "text",
      "id": "margin",
      "label": "t:sections.common.section_margin",
      "info": "t:sections.common.order_info"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "t:sections.common.section_padding",
      "info": "t:sections.common.order_info"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.common.background_color"
    },
    {
      "type": "select",
      "id": "slideshow_height",
      "label": "t:sections.slideshow.settings.slideshow_height",
      "default": "auto-height",
      "options": [
        { "value": "auto-height", "label": "t:sections.common.auto" },
        { "value": "full-height", "label": "t:sections.slideshow.settings.full_screen" },
        { "value": "fix-height", "label": "t:sections.slideshow.settings.manually" }
      ]
    },
    {
      "type": "range",
      "id": "manually_height",
      "label": "t:sections.slideshow.settings.manually_height",
      "min": 300,
      "max": 700,
      "step": 5,
      "unit": "px",
      "default": 425
    },
    {
      "type": "checkbox",
      "id": "disable_lazyload",
      "label": "t:sections.slideshow.settings.disable_lazyload",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "push_layout_right",
      "label": "t:sections.slideshow.settings.push_layout_to_right"
    },
    {
      "type": "header",
      "content": "t:sections.common.slider_settings"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "t:sections.common.loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "t:sections.common.controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "dots",
      "label": "t:sections.common.dots",
      "default": true
    },
    {
      "type": "range",
      "id": "dots_bottom_offset",
      "label": "Pagination Dots Bottom Offset",
      "info": "Pixel-based offset for precise positioning.",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "dots_bottom_offset_mobile",
      "label": "Pagination Dots Bottom Offset (Mobile)",
      "info": "Pixel-based offset for precise positioning for mobile.",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.common.autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_timeout",
      "label": "t:sections.common.autoplay_timeout",
      "step": 0.1,
      "min": 2,
      "max": 10,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.slideshow.settings.three_image_style"
    },
    {
      "type": "select",
      "id": "three_banner_style",
      "label": "t:sections.common.style",
      "default": "1",
      "options": [
        { "value": "1", "label": "t:sections.common.style_1" },
        { "value": "2", "label": "t:sections.common.style_2" }
      ]
    },
    {
      "type": "color",
      "id": "three_image_bg_color",
      "label": "t:sections.common.background_color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.common.block_image"
    },
    {
      "type": "image_picker",
      "id": "three_image_1",
      "label": "t:sections.common.image"
    },
    {
      "type": "textarea",
      "id": "three_text_1",
      "label": "t:sections.common.textbox"
    },
    {
      "type": "text",
      "id": "three_button_1",
      "label": "t:sections.common.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "three_link_1",
      "label": "t:sections.common.button_link"
    },
    {
      "type": "header",
      "content": "t:sections.common.block_image"
    },
    {
      "type": "image_picker",
      "id": "three_image_2",
      "label": "t:sections.common.image"
    },
    {
      "type": "textarea",
      "id": "three_text_2",
      "label": "t:sections.common.textbox"
    },
    {
      "type": "text",
      "id": "three_button_2",
      "label": "t:sections.common.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "three_link_2",
      "label": "t:sections.common.button_link"
    },
    {
      "type": "header",
      "content": "t:sections.common.block_image"
    },
    {
      "type": "image_picker",
      "id": "three_image_3",
      "label": "t:sections.common.image"
    },
    {
      "type": "textarea",
      "id": "three_text_3",
      "label": "t:sections.common.textbox"
    },
    {
      "type": "text",
      "id": "three_button_3",
      "label": "t:sections.common.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "three_link_3",
      "label": "t:sections.common.button_link"
    },
    {
      "type": "header",
      "content": "t:sections.common.block_product"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "t:sections.common.product"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "t:sections.common.product"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "t:sections.common.product"
    }
  ],
  "blocks": [
    {
      "type": "block-item",
      "name": "t:sections.slideshow.blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.common.image_desktop"
